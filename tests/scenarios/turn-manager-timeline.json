{
  "id": "turn_manager_timeline",
  "name": "Turn manager full timeline - reprompt, nudge, timeout",
  "description": "Verifies the complete turn management lifecycle: question -> clarification request -> clarification -> 12h gentle nudge -> 24h silent timeout that defers the pending question to the next check-in.",
  "user": {
    "phoneNumber": "test_turn_timeline"
  },
  "script": [
    {
      "action": "reset"
    },
    {
      "action": "load_persona",
      "personaId": "controlled_asthma"
    },
    {
      "action": "advance",
      "to": "next_checkin"
    },
    {
      "action": "send",
      "text": "I don't understand the question"
    },
    {
      "action": "advance",
      "to": "next_day"
    },
    {
      "action": "trigger_pending_nudge"
    },
    {
      "action": "advance",
      "to": "next_day"
    },
    {
      "action": "trigger_expired_pending"
    },
    {
      "action": "advance",
      "to": "next_checkin"
    }
  ],
  "expectations": [
    {
      "afterStep": 4,
      "type": "message",
      "op": "contains",
      "value": "asking",
      "caseInsensitive": true,
      "description": "Clarification request triggers an explanation of the pending question"
    },
    {
      "afterStep": 6,
      "type": "message",
      "op": "contains",
      "value": "gentle nudge",
      "caseInsensitive": true,
      "description": "12h pending question nudge is sent"
    },
    {
      "afterStep": 9,
      "type": "message",
      "op": "contains",
      "value": "Before we move on:",
      "description": "24h timeout defers the question; next check-in re-raises it"
    }
  ]
}
