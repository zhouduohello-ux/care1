{
  "id": "turn_manager_clarification",
  "name": "Turn Manager answers clarification request",
  "description": "When the user asks for clarification instead of answering the pending question, the system explains the question and lists the available options without counting it as a failed reprompt.",
  "user": {
    "phoneNumber": "test_turn_clarification"
  },
  "script": [
    { "action": "reset" },
    { "action": "load_persona", "personaId": "controlled_asthma" },
    { "action": "advance", "to": "next_checkin" },
    { "action": "send", "text": "What do you mean?" },
    { "action": "reply", "buttonId": "night_none" }
  ],
  "expectations": [
    {
      "afterStep": 4,
      "type": "message",
      "op": "contains",
      "value": "asking",
      "caseInsensitive": true,
      "description": "System explains the pending question"
    },
    {
      "afterStep": 4,
      "type": "message",
      "op": "contains",
      "value": "reply with",
      "caseInsensitive": true,
      "description": "System lists reply options"
    },
    {
      "afterStep": 5,
      "type": "planner",
      "path": "nextAction.topic",
      "op": "eq",
      "value": "reliever_use",
      "description": "After clarification, the system moves to the next question"
    }
  ]
}
