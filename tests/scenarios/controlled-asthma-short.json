{
  "id": "controlled_asthma_short",
  "name": "Controlled asthma - onboarding + two check-ins + disease card",
  "description": "A shortened happy-path journey that loads the controlled_asthma persona, completes two check-ins, and verifies a Disease Card is generated.",
  "user": {
    "phoneNumber": "test_controlled_short"
  },
  "script": [
    { "action": "reset" },
    { "action": "load_persona", "personaId": "controlled_asthma" },
    { "action": "advance", "to": "next_checkin" },
    { "action": "reply", "buttonId": "night_none" },
    { "action": "reply", "buttonId": "reliever_0" },
    { "action": "reply", "buttonId": "activity_no" },
    { "action": "advance", "to": "next_checkin" },
    { "action": "reply", "buttonId": "night_none" },
    { "action": "reply", "buttonId": "reliever_0" },
    { "action": "reply", "buttonId": "activity_no" }
  ],
  "expectations": [
    {
      "afterStep": 5,
      "type": "message",
      "op": "contains",
      "value": "999",
      "caseInsensitive": true,
      "description": "Asthma-related outbound includes emergency disclaimer"
    },
    {
      "afterStep": 6,
      "type": "planner",
      "path": "nextAction.type",
      "op": "eq",
      "value": "end_session",
      "description": "First check-in ends after budget is used"
    },
    {
      "afterStep": 10,
      "type": "diseaseCard",
      "op": "exists",
      "description": "A Disease Card exists after completed check-ins"
    }
  ]
}
