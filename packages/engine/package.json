{
  "name": "@carememory/engine",
  "version": "0.1.0",
  "private": true,
  "description": "CareMemory six-layer AI-native engine",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external @carememory/disease-card --external @carememory/rag --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@carememory/db": "workspace:*",
    "@carememory/disease-card": "workspace:*",
    "@carememory/im-core": "workspace:*",
    "@carememory/rag": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
