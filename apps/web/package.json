{
  "name": "@carememory/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CareMemory Next.js web app for Disease Card and Brief",
  "scripts": {
    "dev": "dotenv -e ../../.env -- next dev -p ${WEB_PORT:-3051}",
    "build": "next build",
    "start": "next start -p ${WEB_PORT:-3051}",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@carememory/brief-templates": "workspace:*",
    "@carememory/db": "workspace:*",
    "@sentry/nextjs": "^10.58.0",
    "@sentry/react": "^10.58.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
