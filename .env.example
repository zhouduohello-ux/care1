# App
NODE_ENV=development
PORT=3055
APP_BASE_URL=http://localhost:3055
WEB_BASE_URL=http://localhost:3051
API_BASE_URL=http://localhost:3055
WEB_PORT=3051
ENCRYPTION_KEY=change-me-to-a-32-byte-random-string!!
JWT_SECRET=change-me-to-a-random-jwt-secret

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=$SENTRY_DSN
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0
RELEASE=dev
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://carememory:carememory@localhost:5435/carememory?schema=public

# Redis (BullMQ + cache)
REDIS_URL=redis://localhost:6381

# Meta WhatsApp (MVP can leave empty; local test tool does not need real credentials)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me-verify-token
WHATSAPP_APP_SECRET=

# ── LLM Configuration ──────────────────────────────────────────────────
# Centralised via loadLLMConfig() in @carememory/engine.
# No hardcoded defaults — env is the sole source of truth.
#
# Two independent providers: CHAT (perception/dialogue/safety) and REASON (planner).
# Each provider has its own API_KEY, BASE_URL, and MODEL.
# If provider-specific vars are unset, fall back to the global LLM_* vars below.
# Old names (OPENAI_*, DEFAULT_*_MODEL) still work as bottom-level fallbacks.
#
# ── Chat provider (perception, dialogue, safety) ────────────────────────
# LLM_CHAT_API_KEY=
# LLM_CHAT_BASE_URL=
# LLM_CHAT_MODEL=
#
# ── Reasoning provider (planner only) ────────────────────────────────────
# LLM_REASON_API_KEY=
# LLM_REASON_BASE_URL=
# LLM_REASON_MODEL=
#
# Minimal example — same provider for both (global vars):
#   LLM_API_KEY=sk-openai-xxx
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_DEFAULT_MODEL=gpt-4o-mini
#
# Dual-provider example (DeepSeek chat + DeepSeek reason):
#   LLM_CHAT_API_KEY=sk-deepseek-xxx
#   LLM_CHAT_BASE_URL=https://api.deepseek.com/v1
#   LLM_CHAT_MODEL=deepseek-chat
#   LLM_REASON_API_KEY=sk-deepseek-xxx
#   LLM_REASON_BASE_URL=https://api.deepseek.com/v1
#   LLM_REASON_MODEL=deepseek-reasoner
#
# Per-layer model override (optional, overrides the provider default):
#   LLM_MODEL_PERCEPTION=
#   LLM_MODEL_PLANNER=
#   LLM_MODEL_DIALOGUE=
#   LLM_MODEL_SAFETY=
#
# Temperature (global default 0.3 if unset):
#   LLM_TEMPERATURE=
#   LLM_TEMPERATURE_PERCEPTION=
#   LLM_TEMPERATURE_PLANNER=
#   LLM_TEMPERATURE_DIALOGUE=
#   LLM_TEMPERATURE_SAFETY=
#
LLM_API_KEY=
# LLM_BASE_URL=
# LLM_DEFAULT_MODEL=
LLM_TEMPERATURE=
LLM_FALLBACK_MODEL=
LLM_DAILY_LIMIT_USER=50
# Minimum LLM confidence (0-1) required for the dialogue-layer fallback to accept a free-text reply as an answer to a pending question.
# LLM_ANSWER_RELEVANCE_THRESHOLD=0.7
# ── Legacy LLM env vars (still work, but prefer LLM_* above) ───────────
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# DEFAULT_PERCEPTION_MODEL=
# DEFAULT_PLANNER_MODEL=
# DEFAULT_DIALOGUE_MODEL=
# DEFAULT_SAFETY_MODEL=

# A/B experiments (format: comma-separated weights; use ENABLED=false to disable)
EXPERIMENT_CHECKIN_FREQUENCY_ENABLED=true
EXPERIMENT_CHECKIN_FREQUENCY_SPLIT=50,50
EXPERIMENT_CONVERSATION_STYLE_ENABLED=true
EXPERIMENT_CONVERSATION_STYLE_SPLIT=80,20

# Scheduler / turn management tuning (milliseconds)
# PENDING_QUESTION_NUDGE_AFTER_MS=43200000
# PENDING_QUESTION_TIMEOUT_MS=86400000
# Scheduler / turn management tuning
# PENDING_QUESTION_MAX_REPROMPTS=2