# App
NODE_ENV=development
PORT=3055
APP_BASE_URL=http://localhost:3055
WEB_BASE_URL=http://localhost:3051
API_BASE_URL=http://localhost:3055
WEB_PORT=3051
ENCRYPTION_KEY=change-me-to-a-32-byte-random-string!!
JWT_SECRET=change-me-to-a-random-jwt-secret

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=$SENTRY_DSN
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0
RELEASE=dev
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://carememory:carememory@localhost:5435/carememory?schema=public

# Redis (BullMQ + cache)
REDIS_URL=redis://localhost:6381

# Meta WhatsApp (MVP can leave empty; local test tool does not need real credentials)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me-verify-token
WHATSAPP_APP_SECRET=

# LLM
OPENAI_API_KEY=
# Optional: for OpenAI-compatible endpoints (Azure, vLLM, Ollama, etc.)
OPENAI_BASE_URL=
DEFAULT_PLANNER_MODEL=gpt-4o-mini
DEFAULT_DIALOGUE_MODEL=gpt-4o-mini
DEFAULT_PERCEPTION_MODEL=gpt-4o-mini
DEFAULT_SAFETY_MODEL=gpt-4o-mini
LLM_DAILY_LIMIT_USER=50
LLM_FALLBACK_MODEL=gpt-4o-mini

# A/B experiments (format: comma-separated weights; use ENABLED=false to disable)
EXPERIMENT_CHECKIN_FREQUENCY_ENABLED=true
EXPERIMENT_CHECKIN_FREQUENCY_SPLIT=50,50
EXPERIMENT_CONVERSATION_STYLE_ENABLED=true
EXPERIMENT_CONVERSATION_STYLE_SPLIT=80,20

# Optional: LLM observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# Optional: object storage for PDFs
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-west-2

# Optional: email
RESEND_API_KEY=

# Optional: doctor feedback link embedded in Brief page/PDF (e.g. Typeform / Google Form)
DOCTOR_FEEDBACK_URL=

# Local test tool (dev only)
ENABLE_TEST_TOOL=true
